# MediPass — Environment Variables
# Copyright (c) 2026 Uvin Vindula — IAMUVIN (iamuvin.com)
# Copy to .env.local and fill real values. NEVER commit .env.local.

# ─── Terminal 3 Network (live ADK — WASM SDK + SIWE) ──────────────────
# The test key from the ADK signup is an Ethereum PRIVATE KEY used for SIWE
# auth via @terminal3/t3n-sdk — NOT a REST bearer token. The SDK resolves the
# node URL from T3N_ENV; there is no base URL to set.
T3N_DEMO_KEY=0x66160ba24c43fc85fdad5f787b40385730f79de2e1713f4ba81d4bdeb08bc438
T3N_ENV=testnet
T3N_AGENT_PRIVATE_KEY=    # agent signing key (defaults to T3N_DEMO_KEY) — NEVER COMMIT
T3N_AGENT_DID=            # from: pnpm setup:agent (did:t3n:...)
T3N_VC_ISSUER_SCRIPT=     # optional: z:<tid>:<path> of the VC issuer contract

# ─── Anthropic ────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=

# ─── Auth (NextAuth.js v5) ────────────────────────────────────────────
NEXTAUTH_SECRET=          # openssl rand -base64 32
NEXTAUTH_URL=http://localhost:3000

# ─── Supabase PostgreSQL ──────────────────────────────────────────────
DATABASE_URL=             # Transaction mode — port 6543
DIRECT_URL=               # Direct connection — port 5432

# ─── Email (Resend) ───────────────────────────────────────────────────
RESEND_API_KEY=
RESEND_FROM_EMAIL=noreply@medipass.iamuvin.com

# ─── Canary ───────────────────────────────────────────────────────────
CANARY_ALLOWED_ORIGINS=http://localhost:3000,https://medipass.vercel.app,https://medipass.iamuvin.com

# ─── App ──────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000
NODE_ENV=development
